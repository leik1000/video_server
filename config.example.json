{
  "api_token": "replace-with-a-long-random-secret",
  "public_base_url": "https://video.example.com/videos",
  "storage_dir": "./data/videos",
  "metadata_file": "./data/video_index.json",
  "max_upload_mb": 1024,
  "max_storage_gb": 100,
  "prune_storage_gb": 1,
  "cleanup_interval_seconds": 3600,
  "allowed_extensions": ["mp4", "webm", "mov"],
  "allowed_content_types": [
    "video/mp4",
    "video/webm",
    "video/quicktime",
    "application/octet-stream"
  ]
}
